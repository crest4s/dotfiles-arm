add_chaotic_repo() {
    # Chaotic AUR does not provide aarch64 packages тАФ skip entirely on ARM.
    # eww-git will be built from source via paru in install_chaotic_dependencies().
    if [ "$(uname -m)" = "aarch64" ]; then
        clear
        logo "Chaotic AUR тАФ skipped on ARM"
        sleep 2
        printf "%b\n\n" "${BLD}${CYE}Chaotic AUR has no aarch64 mirrors. ${CGR}eww-git${CYE} will be built from AUR source.${CNC}"
        sleep 3
        return 0
    fi

    clear
    logo "Add chaotic-aur repository"
    repo_chaotic="chaotic-aur"
    key_id="3056513887B78AEB"
    sleep 2

    printf "%b\n" "${BLD}${CYE}Installing ${CBL}${repo_chaotic}${CYE} repository...${CNC}"

    # GPG key management
    if ! pacman-key -f "$key_id" >/dev/null 2>&1; then
        printf "%b\n" "${BLD}${CYE}Adding GPG key...${CNC}"
        sudo pacman-key --recv-key "$key_id" --keyserver keyserver.ubuntu.com

        printf "%b\n" "${BLD}${CYE}Signing key locally...${CNC}"
        sudo pacman-key --lsign-key "$key_id"
    else
        printf "\n%b\n" "${BLD}${CYE}GPG key already exists in keyring${CNC}"
    fi

    # Instalaci├│n de paquetes requeridos
    sudo pacman -U --noconfirm --needed 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-keyring.pkg.tar.zst'
    sudo pacman -U --noconfirm --needed 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-mirrorlist.pkg.tar.zst'

    # Check if repository already exists in pacman.conf
    if ! grep -q "\[${repo_chaotic}\]" /etc/pacman.conf; then
        printf "\n%b\n" "${BLD}${CYE}Adding repository to pacman.conf...${CNC}"
        printf "\n[%s]\nInclude = /etc/pacman.d/chaotic-mirrorlist\n" "$repo_chaotic" \
            | sudo tee -a /etc/pacman.conf

        printf "%b\n" "\n${BLD}${CBL}${repo_chaotic} ${CGR}Repository configured successfully!${CNC}"
        sleep 3
    else
        printf "%b\n" "\n${BLD}${CYE}Repository already exists in pacman.conf${CNC}"
        sleep 3
    fi

}

install_dependencies() {
    clear
    logo "Installing needed packages from official repositories..."
    sleep 2

    sudo pacman -Syy
    # xorg-xinit xorg-server: required for startx / X11 session
    # lightdm lightdm-gtk-greeter: display manager (handles DRM master on ARM/VM)
    # mpd removed from here тАФ built from AUR in install_aur_dependencies (pacman version has x86-only sonames on ARM)
    dependencies="alacritty base-devel bat brightnessctl bspwm clipcat dunst eza feh fzf thunar tumbler gvfs-mtp firefox geany git imagemagick jq jgmenu kitty libwebp maim mpc mpv neovim xcolor ncmpcpp npm pamixer pacman-contrib papirus-icon-theme picom playerctl polybar lxsession python-gobject redshift rofi rustup sxhkd xclip xdg-user-dirs xdo xdotool xsettingsd xorg-xdpyinfo xorg-xkill xorg-xprop xorg-xrandr xorg-xsetroot xorg-xwininfo xorg-xrdb xorg-xinit xorg-server lightdm lightdm-gtk-greeter yazi zsh zsh-autosuggestions zsh-history-substring-search zsh-syntax-highlighting ttf-inconsolata ttf-jetbrains-mono ttf-jetbrains-mono-nerd ttf-terminus-nerd ttf-ubuntu-mono-nerd webp-pixbuf-loader"

    # Arrays temporales
    failed_deps=""
    retry_failed=""

    # First pass
    for pkg in $dependencies; do
        sleep 0.50
        if ! sudo pacman -S --noconfirm --needed "$pkg"; then
            failed_deps="$failed_deps $pkg"
        fi
    done

    # If there were failures, try again
    if [ -n "$failed_deps" ]; then
        printf "\n%b\n" "${BLD}${CRE}These dependencies failed:${CYE}${failed_deps}${CNC}"
        printf "%b\n\n" "${BLD}${CYE}Retrying installation..${CNC}"

        for pkg in $failed_deps; do
            sleep 0.50
            if ! sudo pacman -S --noconfirm --needed "$pkg"; then
                retry_failed="$retry_failed $pkg"
            fi
        done
    fi

    # Final Result
    if [ -n "$retry_failed" ]; then
        printf "\n%b\n" "${BLD}${CRE}These dependencies could not be installed after two attempts:${CYE}${retry_failed}${CNC}"
        printf "%b\n\n" "${BLD}${CBL}missing_apps.txt ${CYE}file was created on your ${CGR}HOME ${CYE}with the list."
        printf "The following dependencies failed, please install manually:\n%s\n" "$retry_failed" > missing_apps.txt
    else
        if [ -z "$failed_deps" ]; then
            printf "\n%b\n" "${BLD}${CGR}All dependencies were installed successfully.${CNC}"
        else
            printf "\n%b\n" "${BLD}${CGR}All dependencies were installed successfully after retry${CNC}"
        fi
    fi
    sleep 3
}

install_theme_dependencies() {
    clear
    logo "Installing theme packages (ARM/aarch64)..."
    sleep 2

    # GTK themes, icon themes, and cursor themes from gh0stzk contain NO compiled
    # binaries тАФ only CSS, SVG, PNG, and xcursor files. Even though the repo only
    # publishes x86_64 packages, the contents are architecture-independent and can
    # be extracted with bsdtar (part of libarchive, always available on Arch Linux).
    # Only st-gh0stzk is skipped because it IS a compiled x86_64 binary; it is
    # replaced by building 'st' from source via paru (AUR).

    gh0stzk_repo_url="http://gh0stzk.github.io/pkgs/x86_64"
    gh0stzk_db_url="${gh0stzk_repo_url}/gh0stzk-dotfiles.db"
    theme_tmpdir=$(mktemp -d)
    failed_themes=""

    printf "%b\n" "${BLD}${CYE}Downloading gh0stzk package database...${CNC}"

    if ! curl -fsSL --retry 3 "$gh0stzk_db_url" -o "${theme_tmpdir}/gh0stzk-dotfiles.db"; then
        printf "%b\n" "${BLD}${CRE}Could not reach gh0stzk package database. Check your connection.${CNC}"
        rm -rf "$theme_tmpdir"
        sleep 3
        return 1
    fi

    mkdir -p "${theme_tmpdir}/db"
    tar -xf "${theme_tmpdir}/gh0stzk-dotfiles.db" -C "${theme_tmpdir}/db"

    printf "%b\n\n" "${BLD}${CYE}Extracting and installing theme files...${CNC}"

    for pkg_desc in "${theme_tmpdir}/db"/*/desc; do
        [ -f "$pkg_desc" ] || continue

        pkg_name=$(awk '/^%NAME%/{getline; print; exit}' "$pkg_desc")
        pkg_file=$(awk '/^%FILENAME%/{getline; print; exit}' "$pkg_desc")

        # st-gh0stzk is an x86_64 compiled binary тАФ skip it, install 'st' from AUR below
        if [ "$pkg_name" = "st-gh0stzk" ]; then
            printf "%b\n" "${BLD}${CYE}  Skipping ${pkg_name} (x86_64 binary тАФ replaced by AUR 'st')${CNC}"
            continue
        fi

        printf "%b\n" "${BLD}${CBL}  тЖТ ${pkg_name}${CNC}"

        if curl -fsSL --retry 3 "${gh0stzk_repo_url}/${pkg_file}" \
               -o "${theme_tmpdir}/${pkg_file}"; then
            # bsdtar extracts to / respecting the package's internal paths (usr/share/...)
            # --exclude filters out pacman metadata files (no binaries are present anyway)
            if sudo bsdtar -xf "${theme_tmpdir}/${pkg_file}" -C / \
                    --exclude '.PKGINFO' \
                    --exclude '.BUILDINFO' \
                    --exclude '.MTREE'    \
                    --exclude '.INSTALL'  2>/dev/null; then
                printf "%b\n" "    ${BLD}${CGR}OK${CNC}"
            else
                printf "%b\n" "    ${BLD}${CRE}extraction failed${CNC}"
                failed_themes="$failed_themes $pkg_name"
            fi
        else
            printf "%b\n" "    ${BLD}${CRE}download failed${CNC}"
            failed_themes="$failed_themes $pkg_name"
        fi
    done

    rm -rf "$theme_tmpdir"

    # Install st from AUR as replacement for st-gh0stzk (compiles natively on aarch64)
    printf "\n%b\n" "${BLD}${CYE}Installing st terminal from AUR (replaces st-gh0stzk)...${CNC}"
    if ! paru -S --skipreview --noconfirm st; then
        printf "%b\n" "${BLD}${CYE}  st optional тАФ alacritty and kitty are already installed${CNC}"
    fi

    if [ -n "$failed_themes" ]; then
        printf "\n%b\n" "${BLD}${CRE}These theme packages failed:${CYE}${failed_themes}${CNC}"
        printf "%b\n\n" "${BLD}${CBL}missing_apps.txt${CYE} created in ${CGR}HOME${CYE} with the list.${CNC}"
        printf "\nTheme packages (ARM)\n=======================\nInstall manually from: %s\n%s\n" \
            "$gh0stzk_repo_url" "$failed_themes" >> "$HOME/missing_apps.txt"
    else
        printf "\n%b\n" "${BLD}${CGR}All theme packages installed successfully.${CNC}"
    fi

    sleep 3
}

install_chaotic_dependencies() {
    clear
    logo "Installing eww-git..."
    sleep 2

    chaotic_dependencies="eww-git"

    # Arrays temporales
    failed_chaotic_deps=""
    retry_chaotic_failed=""

    # On ARM chaotic-aur is not available тАФ go straight to paru
    if [ "$(uname -m)" = "aarch64" ]; then
        printf "%b\n" "${BLD}${CYE}ARM detected тАФ building ${CBL}eww-git${CYE} from AUR source...${CNC}"
        for chaotic_pkg in $chaotic_dependencies; do
            sleep 0.50
            if ! paru -S --skipreview --noconfirm "$chaotic_pkg"; then
                retry_chaotic_failed="$retry_chaotic_failed $chaotic_pkg"
            fi
        done
    else
        # First pass via pacman (chaotic-aur)
        for chaotic_pkg in $chaotic_dependencies; do
            sleep 0.50
            if ! sudo pacman -S --noconfirm --needed "$chaotic_pkg"; then
                failed_chaotic_deps="$failed_chaotic_deps $chaotic_pkg"
            fi
        done

        # Fallback to paru if pacman failed
        if [ -n "$failed_chaotic_deps" ]; then
            printf "\n%b\n" "${BLD}${CRE}Chaotic AUR failed:${CYE}${failed_chaotic_deps}${CNC}"
            printf "%b\n\n" "${BLD}${CYE}Retrying via paru...${CNC}"
            for chaotic_pkg in $failed_chaotic_deps; do
                sleep 0.50
                if ! paru -S --skipreview --noconfirm "$chaotic_pkg"; then
                    retry_chaotic_failed="$retry_chaotic_failed $chaotic_pkg"
                fi
            done
        fi
    fi

    # Final Result
    if [ -n "$retry_chaotic_failed" ]; then
        printf "\n%b\n" "${BLD}${CRE}These dependencies could not be installed after two attempts:${CYE}${retry_chaotic_failed}${CNC}"
        printf "%b\n\n" "${BLD}${CBL}missing_apps.txt ${CYE}file was created on your ${CGR}HOME ${CYE}with the list."
        printf "\nApps from Chaotic/AUR\n=======================\nInstall with paru command.\nThe following dependencies failed, please install manually:\n%s\n" "$retry_chaotic_failed" >> missing_apps.txt
    else
        if [ -z "$failed_chaotic_deps" ]; then
            printf "\n%b\n" "${BLD}${CGR}All dependencies were installed successfully.${CNC}"
        else
            printf "\n%b\n" "${BLD}${CGR}All dependencies were installed successfully after retry${CNC}"
        fi
    fi
    sleep 3
}

install_aur_dependencies() {
    clear
    logo "Installing AUR dependencies..."
    sleep 2

    if ! command -v paru >/dev/null 2>&1; then
        printf "%b\n" "${BLD}${CYE}Configuring Rust toolchain...${CNC}"
        rustup default stable

        printf "%b\n" "${BLD}${CYE}Installing PARU${CNC}"
        git clone https://aur.archlinux.org/paru.git
        cd paru
        makepkg -si --noconfirm
        cd
    fi

    # xwinwrap-0.9-bin is a prebuilt x86_64 binary тАФ replaced with xwinwrap-git (source build, ARM compatible)
    # mpd: pacman version has x86_64-only sonames (libixml.so.11-64 / libupnp.so.17-64); build from AUR instead
    # eww-git: Chaotic AUR has no aarch64 builds; build from AUR source
    aur_dependencies="xwinwrap-git i3lock-color simple-mtpfs fzf-tab-git mpd eww-git"

    # Arrays temporales
    failed_aur_deps=""
    retry_aur_failed=""

    # First pass
    for aur_pkg in $aur_dependencies; do
        sleep 0.50
        if ! paru -S --skipreview --noconfirm "$aur_pkg"; then
            failed_aur_deps="$failed_aur_deps $aur_pkg"
        fi
    done

    # If there were failures, try again
    if [ -n "$failed_aur_deps" ]; then
        printf "\n%b\n" "${BLD}${CRE}These dependencies failed:${CYE}${failed_aur_deps}${CNC}"
        printf "%b\n\n" "${BLD}${CYE}Retrying installation..${CNC}"

        for aur_pkg in $failed_aur_deps; do
            sleep 0.50
            if ! paru -S --skipreview --noconfirm "$aur_pkg"; then
                retry_aur_failed="$retry_aur_failed $aur_pkg"
            fi
        done
    fi

    # Final Result
    if [ -n "$retry_aur_failed" ]; then
        printf "\n%b\n" "${BLD}${CRE}These dependencies could not be installed after two attempts:${CYE}${retry_aur_failed}${CNC}"
        printf "%b\n\n" "${BLD}${CBL}missing_apps.txt ${CYE}file was created on your ${CGR}HOME ${CYE}with the list."
        printf "\nApps from AUR\n=======================\nInstall with paru command.\nThe following dependencies failed, please install manually:\n%s\n" "$retry_aur_failed" >> missing_apps.txt
    else
        if [ -z "$failed_aur_deps" ]; then
            printf "\n%b\n" "${BLD}${CGR}All dependencies were installed successfully.${CNC}"
        else
            printf "\n%b\n" "${BLD}${CGR}All dependencies were installed successfully after retry${CNC}"
        fi
    fi
    sleep 3
}

clone_dotfiles() {
    clear
    logo "Downloading dotfiles"
    repo_url="https://github.com/crest4s/dotfiles-arm"
    repo_dir="$HOME/.local/share/gh0stzk"
    timestamp=$(date +"%Y%m%d-%H%M%S")
    sleep 2

    # Handle existing repository
    if [ -d "$repo_dir" ]; then
        backup_dir="${repo_dir}_$timestamp"
        printf "%b\n" "${BLD}${CYE}Existing repository found - renaming to: ${CBL}${backup_dir}${CNC}"

        mv -v "$repo_dir" "$backup_dir"
    fi

    # Clone new repository
    printf "%b\n" "${BLD}${CYE}Cloning dotfiles from: ${CBL}${repo_url}${CNC}"
    git clone --depth=1 "$repo_url" "$repo_dir"
    sleep 3
}

